APP_ENV=development
API_PORT=8080
MAX_UPLOAD_SIZE_MB=10
ALLOWED_FILE_TYPES=pdf,docx,txt

POSTGRES_URL=postgres://postgres:postgres@localhost:5432/infographic_generator?sslmode=disable

MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=documents
MINIO_USE_SSL=false
MINIO_AUTO_CREATE_BUCKET=true
MINIO_MULTIPART_THRESHOLD_MB=16
MINIO_MULTIPART_PART_SIZE_MB=8

AUTO_PROCESS_DOCUMENTS=true
PROCESSING_QUEUE_BUFFER=16
PROCESSING_STEP_DELAY_MS=400
PROCESSING_FAIL_PATTERN=fail
